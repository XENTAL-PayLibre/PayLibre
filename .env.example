# PayLibre API — environment configuration template.
# Copy to `.env` and adjust per environment. `.env` is git-ignored.
# Double underscore maps to nested config keys in .NET (e.g. ConnectionStrings__Default -> ConnectionStrings:Default).

# ---- ASP.NET Core runtime ----
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_HTTP_PORTS=8080

# ---- Docker host port mapping ----
# Host port the API is published on (container always listens on 8080).
API_PORT=8081

# ---- Database (Postgres) ----
ConnectionStrings__Default=Host=localhost;Port=5432;Database=paylibre;Username=paylibre;Password=changeme

# ---- Dashboard session JWT (HttpOnly cookie) ----
# SigningKey must be >= 32 bytes. Generate: openssl rand -base64 48
Jwt__SigningKey=change-me-to-a-long-random-secret-at-least-32-bytes
Jwt__Issuer=paylibre
Jwt__Audience=paylibre-dashboard
Jwt__AccessTokenLifetimeSeconds=900

# ---- Auth cookies ----
# CookieSecure=true requires HTTPS (leave true everywhere except local plain-http dev).
Auth__BcryptWorkFactor=12
Auth__CookieSecure=false
Auth__CookieSameSite=Lax
Auth__CookieDomain=

# ---- Xental integration (PayLibre's ONLY external dependency) ----
# Sandbox: https://api.staging.xental.online   Live: https://api.xental.online
# Create an API key in the Xental dashboard (Settings -> Developers); copy the client id + secret.
Xental__BaseUrl=https://api.staging.xental.online
Xental__ClientId=
Xental__ClientSecret=

# ---- PayLibre application settings ----
# Platform fee taken on each school's settlement, in basis points (1% = 100). Default 0.
PayLibre__PlatformFeeBps=0
PayLibre__RefreshTokenDays=14
PayLibre__MaxCsvRows=2000

# ---- CORS ----
# Comma-separated frontend origin(s) allowed to send the HttpOnly session cookies.
Cors__AllowedOrigins=http://localhost:3000

# ---- Logging ----
# LOG_DIRECTORY=/app/logs
